graph TB
    subgraph "Sawala Architecture"
        subgraph "User Interface"
            PWA[Web Browser PWA<br/>htmx + Alpine.js]
            Offline[Offline Absensi<br/>IndexedDB Outbox]
        end

        subgraph "Application Layer - Laravel"
            Blade[Blade Templates<br/>Server-Side Rendering]
            Auth[Session Auth<br/>RBAC 4 Roles]
            Akademik[Akademik Service<br/>Absensi, Nilai, Jadwal, Tugas]
            Ibadah[Ibadah Service<br/>Mutabaah, Hafalan Quran]
            SPP[SPP Billing Service<br/>Tagihan & Pembayaran]
            Filament[Filament Admin<br/>Panel Tata Usaha]
        end

        subgraph "Data Layer"
            Eloquent[Eloquent ORM<br/>Schema Migrations]
            MySQL[(MySQL / MariaDB)]
            S3[(S3-Compatible<br/>Media Galeri)]
        end

        subgraph "Integrasi - Phase 4"
            Gateway[SNAP Payment Gateway<br/>VA / QRIS]
            Balaka[Balaka REST<br/>Journal Posting]
        end
    end

    PWA -->|HTTP| Blade
    Offline -->|Idempotent Replay| Akademik
    Blade --> Auth
    Blade --> Akademik
    Blade --> Ibadah
    Blade --> SPP
    Filament --> SPP

    Akademik --> Eloquent
    Ibadah --> Eloquent
    SPP --> Eloquent
    Eloquent --> MySQL
    Filament --> S3

    SPP -.-> Gateway
    SPP -.-> Balaka

